{
  "manifest_version": 3,
  "name": "X Bookmark Summarizer",
  "version": "0.1.4",
  "description": "Collect posts from your logged-in X bookmarks page and summarize them with your OpenAI API key.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://x.com/i/bookmarks*",
    "https://twitter.com/i/bookmarks*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/i/bookmarks*",
        "https://twitter.com/i/bookmarks*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "X Bookmark Summarizer",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
